<section id="about" data-animate class="relative border-t border-border px-6 md:px-16 py-24 md:py-32 overflow-hidden">
  <div class="hidden md:block blob-diamond size-56 bg-orange/5 absolute -top-20 -right-16" aria-hidden="true"></div>
  <div class="max-w-5xl">
    <h2 class="font-display text-lg md:text-xl text-orange uppercase tracking-[0.15em] font-medium mb-8">
