---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Kiznavierr — Backend Developer",
  description = "Portfolio Kiznavierr (Akmal) — backend developer, TypeScript, Node.js, mahasiswa Teknik Informatika.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="theme-color" content="#090909" />
    <title>{title}</title>
  </head>
  <body class="bg-bg text-text">
    <slot />
  </body>
</html>
